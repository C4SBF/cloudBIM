# =============================================================================
# Onuma Custom Aspect Classes (S223 EnumerationKind-Aspect)
# =============================================================================
# These define custom aspects for s223:hasProperty pattern compliance

:EntityType a s223:Class, s223:EnumerationKind, sh:NodeShape ;
    rdfs:label "Entity Type" ;
    rdfs:comment "Onuma entity type classification (site, building, floor, space, component, floor_component)." ;
    rdfs:subClassOf s223:EnumerationKind-Aspect .

:OnumaId a s223:Class, s223:EnumerationKind, sh:NodeShape ;
    rdfs:label "Onuma ID" ;
    rdfs:comment "Unique identifier from Onuma MySQL database for bidirectional sync." ;
    rdfs:subClassOf s223:EnumerationKind-Aspect .

:ExternalId a s223:Class, s223:EnumerationKind, sh:NodeShape ;
    rdfs:label "External ID" ;
    rdfs:comment "External system identifier (e.g., Speckle object ID, BIM GUID)." ;
    rdfs:subClassOf s223:EnumerationKind-Aspect .

:Name a s223:Class, s223:EnumerationKind, sh:NodeShape ;
    rdfs:label "Name" ;
    rdfs:comment "Entity name from Onuma database (space name, floor name, building name, site name). For components, use InstanceName aspect instead." ;
    rdfs:subClassOf s223:EnumerationKind-Aspect .

:ComponentName a s223:Class, s223:EnumerationKind, sh:NodeShape ;
    rdfs:label "Component Name" ;
    rdfs:comment "Component template/type name from Onuma database (component.name field)." ;
    rdfs:subClassOf s223:EnumerationKind-Aspect .

:Number a s223:Class, s223:EnumerationKind, sh:NodeShape ;
    rdfs:label "Number" ;
    rdfs:comment "Entity number from Onuma database (building number, floor number, space number)." ;
    rdfs:subClassOf s223:EnumerationKind-Aspect .

:Level a s223:Class, s223:EnumerationKind, sh:NodeShape ;
    rdfs:label "Level" ;
    rdfs:comment "Floor level number (1-indexed, where level = floor.number + 1)." ;
    rdfs:subClassOf s223:EnumerationKind-Aspect .

:Department a s223:Class, s223:EnumerationKind, sh:NodeShape ;
    rdfs:label "Department" ;
    rdfs:comment "Space department or functional category from Onuma." ;
    rdfs:subClassOf s223:EnumerationKind-Aspect .

:InstanceName a s223:Class, s223:EnumerationKind, sh:NodeShape ;
    rdfs:label "Instance Name" ;
    rdfs:comment "Component instance name from Onuma database (component.instance_name field)." ;
    rdfs:subClassOf s223:EnumerationKind-Aspect .

# =============================================================================
# Onuma Custom Property Predicates
# =============================================================================
# These define custom predicates used for property provenance tracking

:sourceAttribute a rdf:Property ;
    rdfs:label "Source Attribute" ;
    rdfs:comment "Records the original MySQL attribute name from which a linked property was derived." ;
    rdfs:domain s223:Property ;
    rdfs:range xsd:string .

:originalValue a rdf:Property ;
    rdfs:label "Original Value" ;
    rdfs:comment "Records the original string value before type conversion for linked properties." ;
    rdfs:domain s223:Property ;
    rdfs:range xsd:string .

# =============================================================================
# Onuma TimeSeries External Reference Classes
# =============================================================================
# These define classes and properties for Onuma TimeSeries API integration
# Used to link sensor observed properties to external time-series data sources

:TimeseriesReference a owl:Class ;
    rdfs:label "Timeseries Reference" ;
    rdfs:comment "External reference to Onuma TimeSeries API for time-series data retrieval. Links sensor observed properties to external data sources." .

:hasTimeseriesId a owl:DatatypeProperty ;
    rdfs:label "has Timeseries ID" ;
    rdfs:comment "Sensor/equipment instance name ID used to query the TimeSeries API." ;
    rdfs:domain :TimeseriesReference ;
    rdfs:range xsd:string .

:storedAt a owl:DatatypeProperty ;
    rdfs:label "stored At" ;
    rdfs:comment "JSON configuration object containing API connection details (base_url, params, value_column)." ;
    rdfs:domain :TimeseriesReference ;
    rdfs:range xsd:string .

